{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/plexusone/design-system-spec/sdk/go/governance",
  "$ref": "#/$defs/Governance",
  "$defs": {
    "ContributionPolicy": {
      "properties": {
        "description": {
          "type": "string"
        },
        "guidelines": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "workflow": {
          "$ref": "#/$defs/ContributionWorkflow"
        },
        "templates": {
          "items": {
            "$ref": "#/$defs/ContributionTemplate"
          },
          "type": "array"
        },
        "codeOfConductUrl": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ContributionTemplate": {
      "properties": {
        "type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ContributionWorkflow": {
      "properties": {
        "steps": {
          "items": {
            "$ref": "#/$defs/WorkflowStep"
          },
          "type": "array"
        },
        "requiredReviewers": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "automatedChecks": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "DecisionProcess": {
      "properties": {
        "description": {
          "type": "string"
        },
        "rfcRequired": {
          "type": "boolean"
        },
        "approvalRequired": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "decisionRecordLocation": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "DeprecatedItem": {
      "properties": {
        "type": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "deprecatedSince": {
          "type": "string"
        },
        "removalDate": {
          "type": "string"
        },
        "replacement": {
          "type": "string"
        },
        "migrationGuideUrl": {
          "type": "string",
          "format": "uri"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "DeprecationPolicy": {
      "properties": {
        "warningPeriod": {
          "type": "string"
        },
        "notificationChannels": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "migrationGuideRequired": {
          "type": "boolean"
        },
        "deprecatedItems": {
          "items": {
            "$ref": "#/$defs/DeprecatedItem"
          },
          "type": "array"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Governance": {
      "properties": {
        "versioning": {
          "$ref": "#/$defs/VersioningPolicy"
        },
        "contribution": {
          "$ref": "#/$defs/ContributionPolicy"
        },
        "deprecation": {
          "$ref": "#/$defs/DeprecationPolicy"
        },
        "decisionProcess": {
          "$ref": "#/$defs/DecisionProcess"
        },
        "ownership": {
          "items": {
            "$ref": "#/$defs/OwnershipRecord"
          },
          "type": "array"
        },
        "supportPolicy": {
          "$ref": "#/$defs/SupportPolicy"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "OwnershipRecord": {
      "properties": {
        "area": {
          "type": "string"
        },
        "team": {
          "type": "string"
        },
        "contactEmail": {
          "type": "string",
          "format": "email"
        },
        "slackChannel": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "SupportPolicy": {
      "properties": {
        "description": {
          "type": "string"
        },
        "supportedVersions": {
          "items": {
            "$ref": "#/$defs/SupportedVersion"
          },
          "type": "array"
        },
        "supportChannels": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "responseTimeTargets": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "SupportedVersion": {
      "properties": {
        "version": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "endOfLifeDate": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "VersioningPolicy": {
      "properties": {
        "strategy": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "breakingChangePolicy": {
          "type": "string"
        },
        "releaseSchedule": {
          "type": "string"
        },
        "changelogLocation": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "WorkflowStep": {
      "properties": {
        "order": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "assignee": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  }
}